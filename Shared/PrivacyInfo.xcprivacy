<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Privacy manifest for Husky Notes. Lives in Shared/ so it's bundled into every
  target (both apps + the share & widget extensions).

  Husky Notes has no server and no analytics: all processing (OCR, scanning,
  transcription, AI) is on-device, and sync uses the user's OWN private CloudKit
  database, which the developer can't access. Hence: no tracking, no collected
  data types. Only Required Reason APIs are declared.
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- App settings/preferences (own defaults) + app-group sharing
			     between the app, the Share Extension, and the Widgets. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
				<string>1C8F.1</string>
			</array>
		</dict>
		<dict>
			<!-- Reading/displaying timestamps of files inside the app's own
			     containers (attachments, exports). Declared per Apple's
			     "when in doubt, declare it" guidance. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
