<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Partial Info.plist for the iOS/iPadOS app. Holds only keys that Xcode's
  GENERATE_INFOPLIST_FILE can't synthesise via INFOPLIST_KEY_* build settings;
  Xcode merges its generated keys (bundle id, version, scene manifest, usage
  descriptions, orientations…) into this file at build time.
-->
<plist version="1.0">
<dict>
	<!-- CloudKit silent pushes that tell the app to pull synced changes. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
